# =============================================================================
# Invest-Scout Configuration
# Copy this file to .env and adjust as needed
# =============================================================================

# --- Data ---
CACHE_TTL_MINUTES=60
ALPHA_VANTAGE_KEY=
DATA_PERIOD=1y

# --- Signal Thresholds ---
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
SMA_SHORT=50
SMA_LONG=200
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
VOLUME_SPIKE_MULTIPLIER=2.0
TRAILING_STOP_PCT=8.0

# --- Email Alerts (off by default) ---
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# --- Server ---
FLASK_PORT=5000
SCAN_INTERVAL_MINUTES=5
